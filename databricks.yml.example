# This is a Databricks asset bundle definition for basket_intelligence_bundle.
# See https://docs.databricks.com/dev-tools/bundles/index.html for documentation.
bundle:
  name: basket_intelligence_bundle

artifacts:
  python_artifact:
    type: whl
    build: uv build --wheel

include:
  - resources/*.yml
  - resources/*/*.yml

# set global parameters for the pipelines 
variables:
  season:
    description: "The nba season from which the data should be loaded"
    default: "2026"

targets:
  dev:
    # The default target uses 'mode: development' to create a development copy.
    # - Deployed resources get prefixed with '[dev my_user_name]'
    # - Any job schedules and triggers are paused by default.
    # See also https://docs.databricks.com/dev-tools/bundles/deployment-modes.html.
    mode: development
    default: true
    workspace:
      host: https://your-workspace-id.cloud.databricks.com/

  prod:
    mode: production
    workspace:
      host:  https://your-workspace-id.cloud.databricks.com/
      # We explicitly deploy to /Workspace/Users/your-mail@example.com to make sure we only have a single copy.
      root_path: /Workspace/Users/your-mail@example.com/.bundle/${bundle.name}/${bundle.target}
    permissions:
      - user_name: your-mail@example.com
        level: CAN_MANAGE